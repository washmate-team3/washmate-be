# Copy file nay thanh .env va dien gia tri that.
# TUYET DOI khong commit credential that vao git.

# Database (bat buoc voi profile supabase)
DB_URL=jdbc:postgresql://HOST:6543/postgres?sslmode=require&prepareThreshold=0
DB_USERNAME=postgres.PROJECT_REF
DB_PASSWORD=replace-me

# Security (bat buoc)
JWT_SECRET=replace-with-at-least-32-random-characters
CORS_ALLOWED_ORIGIN_PATTERNS=http://localhost:*,http://127.0.0.1:*
GOOGLE_CLIENT_ID=
DOCS_ENABLED=false

# OTP (de trong = gui OTP that qua mail; dat gia tri = mock mode cho dev)
OTP_MOCK_CODE=

# VNPAY (bat buoc khi VNPAY_ENABLED=true)
VNPAY_ENABLED=false
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_PAY_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
VNPAY_RETURN_URL=http://localhost:8080/api/payments/vnpay/return
VNPAY_FRONTEND_RESULT_URL=http://localhost:3000/payment/vnpay-return
# Chi bat khi test local (IPN khong toi duoc localhost). Production: false
VNPAY_RETURN_FALLBACK_ENABLED=false

# Mail (Resend)
MAIL_HOST=smtp.resend.com
MAIL_PORT=587
MAIL_USERNAME=resend
MAIL_PASSWORD=
APP_MAIL_FROM=WashMate <no-reply@example.com>

# Supabase Storage
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_AVATAR_BUCKET=avatars

# Gemini AI (cho AutoWash Insight)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
